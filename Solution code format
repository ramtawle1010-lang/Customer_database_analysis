create database customer_database_analysis;
USE customer_database_analysis;

-- Create the Product Table
CREATE TABLE project_product (
    product_id INT PRIMARY KEY,
    product_name VARCHAR(100) NOT NULL,
    price INT NOT NULL
);

-- Create the User Name Table
CREATE TABLE project_user_name (
    userid INT PRIMARY KEY,
    Names VARCHAR(100) NOT NULL
);

-- Create the Users Table (Tracking system signups)
CREATE TABLE project_users (
    userid INT PRIMARY KEY,
    signup_date DATE NOT NULL
);

-- Create the Gold Users Signup Table
CREATE TABLE project_goldusers_signup (
    userid INT PRIMARY KEY,
    gold_signup_date DATE NOT NULL
);

-- Create the Sales Table (With Foreign Key Constraints)
CREATE TABLE project_sales (
    sales_id INT IDENTITY(1,1) PRIMARY KEY, -- Added surrogate PK for best practice
    userid INT NOT NULL,
    created_date DATE NOT NULL,
    product_id INT NOT NULL,
    
    -- Defining relationships as depicted in the ERD
    CONSTRAINT fk_sales_users FOREIGN KEY (userid) 
        REFERENCES project_users(userid),
        
    CONSTRAINT fk_sales_product1 FOREIGN KEY (product_id) 
        REFERENCES project_product(product_id)
);




